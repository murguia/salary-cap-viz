---
import Base from '../../layouts/Base.astro';
import season from '../../../data/nba/2025-26.json';

// Embed the dataset for the client script (escape </script> breakers).
const dataJson = JSON.stringify(season).replace(/</g, '\\u003c');

const totalPayroll = season.totalPayroll;
const fmtBillions = (n: number) => '$' + (n / 1e9).toFixed(2) + 'B';
---

<Base
  title="NBA Payroll Treemap 2025-26 — Salary Cap Viz"
  description="A Mondrian-style treemap of 2025-26 NBA player salaries, grouped by conference and team."
>
  <div class="wrap">
    <header class="viz-head">
      <span class="tag">NBA · 2025-26 Season</span>
      <h1>Mondrian Payroll Treemap</h1>
      <p class="lede">
        Every rectangle is a player, sized by their {season.season} salary.
        Rectangles nest into their team, and teams into the
        <strong>Eastern</strong> and <strong>Western</strong> conferences.
        Adjacent teams never share a color. <strong>Hover</strong> any block to
        name the player.
      </p>
      <dl class="stats">
        <div><dt>Total player salaries</dt><dd>{fmtBillions(totalPayroll)}</dd></div>
        <div><dt>Salary cap</dt><dd>$154.6M</dd></div>
        <div><dt>Luxury tax line</dt><dd>$187.9M</dd></div>
        <div><dt>Second apron</dt><dd>$207.8M</dd></div>
      </dl>
    </header>

    <figure class="chart-figure">
      <div id="chart-container">
        <svg id="chart" viewBox="0 0 1600 1000" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Treemap of 2025-26 NBA player salaries by conference and team"></svg>
      </div>
      <figcaption>
        Area is proportional to salary. Sub-$1M contracts (waived / two-way /
        traded players carrying dead money) appear as slivers — real cap data,
        just tiny. Cap, tax, and apron figures are the official 2025-26 NBA
        thresholds. Salary data via Basketball Reference.
      </figcaption>
    </figure>
  </div>

  <div id="tooltip" class="tooltip" hidden></div>

  <script id="treemap-data" type="application/json" set:html={dataJson} is:inline></script>

  <script>
    import * as d3 from 'd3';

    // ---- constants -------------------------------------------------------
    const W = 1600;
    const H = 1000;
    const TITLE_H = 62; // top strip reserved for conference titles
    const CAP = 154_647_000; // 2025-26 salary cap, for the "% of cap" readout

    // Mondrian palette. Greedy graph-coloring assigns one entry per team so
    // that no two edge-adjacent teams share a fill.
    const PALETTE = [
      { fill: '#f4f1e8', text: '#161616' }, // cream
      { fill: '#ce2029', text: '#ffffff' }, // red
      { fill: '#1f4e9b', text: '#ffffff' }, // blue
      { fill: '#f6c700', text: '#161616' }, // yellow
      { fill: '#d8d3c4', text: '#161616' }, // warm grey
    ];

    const fmtUSD = d3.format('$,.0f');
    const pct = d3.format('.1%');
    const shortM = (s) => '$' + (s / 1e6).toFixed(1) + 'M';

    // ---- data ------------------------------------------------------------
    const data = JSON.parse(
      document.getElementById('treemap-data').textContent,
    );

    const root = d3
      .hierarchy(data, (d) => d.conferences || d.teams || d.players || null)
      .sum((d) => d.salary || 0)
      .sort((a, b) => b.value - a.value);

    // ---- adjacency (from an un-padded layout, so edges touch exactly) ----
    d3.treemap().size([W, H - TITLE_H]).paddingInner(0).paddingOuter(0).round(false)(root);
    const teamNodes = root.descendants().filter((d) => d.depth === 2);
    const bare = new Map(
      teamNodes.map((d) => [d.data.bbref, { x0: d.x0, y0: d.y0, x1: d.x1, y1: d.y1 }]),
    );

    const EPS = 1.0;
    function touch(a, b) {
      const yo = Math.min(a.y1, b.y1) - Math.max(a.y0, b.y0);
      const xo = Math.min(a.x1, b.x1) - Math.max(a.x0, b.x0);
      const shareV =
        (Math.abs(a.x1 - b.x0) <= EPS || Math.abs(b.x1 - a.x0) <= EPS) && yo > EPS;
      const shareH =
        (Math.abs(a.y1 - b.y0) <= EPS || Math.abs(b.y1 - a.y0) <= EPS) && xo > EPS;
      return shareV || shareH;
    }
    const adj = new Map(teamNodes.map((d) => [d.data.bbref, new Set()]));
    for (let i = 0; i < teamNodes.length; i++) {
      for (let j = i + 1; j < teamNodes.length; j++) {
        const a = teamNodes[i].data.bbref;
        const b = teamNodes[j].data.bbref;
        if (touch(bare.get(a), bare.get(b))) {
          adj.get(a).add(b);
          adj.get(b).add(a);
        }
      }
    }

    // ---- greedy coloring (Welsh–Powell order, load-balanced palette) -----
    const order = teamNodes
      .slice()
      .sort((a, b) => {
        const da = adj.get(a.data.bbref).size;
        const db = adj.get(b.data.bbref).size;
        return db - da || b.value - a.value;
      });
    const usage = PALETTE.map(() => 0);
    const colorIdx = new Map();
    for (const t of order) {
      const forbidden = new Set();
      for (const nb of adj.get(t.data.bbref)) {
        if (colorIdx.has(nb)) forbidden.add(colorIdx.get(nb));
      }
      let best = -1;
      for (let i = 0; i < PALETTE.length; i++) {
        if (forbidden.has(i)) continue;
        if (best === -1 || usage[i] < usage[best]) best = i;
      }
      if (best === -1) best = 0;
      colorIdx.set(t.data.bbref, best);
      usage[best]++;
    }

    // ---- padded layout for rendering -------------------------------------
    d3
      .treemap()
      .size([W, H - TITLE_H])
      .paddingInner((d) => (d.depth === 0 ? 18 : d.depth === 1 ? 7 : 3))
      .paddingOuter((d) => (d.depth === 0 ? 8 : d.depth === 1 ? 8 : d.depth === 2 ? 4 : 0))
      .round(true)(root);

    // ---- render ----------------------------------------------------------
    const svg = d3.select('#chart');
    svg.append('rect').attr('x', 0).attr('y', 0).attr('width', W).attr('height', H).attr('fill', '#161616');

    // conference titles in the top strip
    svg
      .selectAll('text.conf')
      .data(root.children)
      .join('text')
      .attr('class', 'conf')
      .attr('x', (d) => (d.x0 + d.x1) / 2)
      .attr('y', TITLE_H / 2)
      .attr('text-anchor', 'middle')
      .attr('dominant-baseline', 'central')
      .attr('fill', '#f4f1e8')
      .attr('font-size', 26)
      .attr('font-weight', 800)
      .attr('letter-spacing', '0.14em')
      .text((d) => d.data.name.toUpperCase() + ' CONFERENCE');

    const plot = svg.append('g').attr('transform', `translate(0, ${TITLE_H})`);

    // player cells
    const leaf = plot
      .selectAll('g.leaf')
      .data(root.leaves())
      .join('g')
      .attr('class', 'leaf')
      .attr('transform', (d) => `translate(${d.x0}, ${d.y0})`);

    leaf
      .append('rect')
      .attr('width', (d) => Math.max(0, d.x1 - d.x0))
      .attr('height', (d) => Math.max(0, d.y1 - d.y0))
      .attr('shape-rendering', 'crispEdges')
      .attr('fill', (d) => PALETTE[colorIdx.get(d.parent.data.bbref)].fill);

    // labels on large player cells
    leaf
      .filter((d) => d.x1 - d.x0 > 74 && d.y1 - d.y0 > 30)
      .each(function (d) {
        const g = d3.select(this);
        const w = d.x1 - d.x0;
        const h = d.y1 - d.y0;
        const ink = PALETTE[colorIdx.get(d.parent.data.bbref)].text;
        const last = d.data.name.split(' ').slice(-1)[0];
        g.append('text')
          .attr('x', 6)
          .attr('y', 16)
          .attr('fill', ink)
          .attr('font-size', 12)
          .attr('font-weight', 700)
          .attr('pointer-events', 'none')
          .text(last.length * 7 < w - 8 ? last : '');
        if (h > 44) {
          g.append('text')
            .attr('x', 6)
            .attr('y', 30)
            .attr('fill', ink)
            .attr('font-size', 10.5)
            .attr('opacity', 0.85)
            .attr('pointer-events', 'none')
            .text(shortM(d.data.salary));
        }
      });

    // team abbreviations
    plot
      .selectAll('text.team')
      .data(teamNodes.filter((d) => d.x1 - d.x0 > 30 && d.y1 - d.y0 > 20))
      .join('text')
      .attr('class', 'team')
      .attr('x', (d) => d.x0 + 4)
      .attr('y', (d) => d.y0 + 13)
      .attr('fill', (d) => PALETTE[colorIdx.get(d.data.bbref)].text)
      .attr('font-size', 12)
      .attr('font-weight', 800)
      .attr('opacity', 0.5)
      .attr('pointer-events', 'none')
      .text((d) => d.data.bbref);

    // hover highlight (two stacked outlines for contrast)
    const hi = plot.append('g').attr('pointer-events', 'none').style('display', 'none');
    const hiBack = hi.append('rect').attr('fill', 'none').attr('stroke', '#161616').attr('stroke-width', 6).attr('shape-rendering', 'crispEdges');
    const hiFront = hi.append('rect').attr('fill', 'none').attr('stroke', '#f4f1e8').attr('stroke-width', 2.5).attr('shape-rendering', 'crispEdges');

    // ---- tooltip ---------------------------------------------------------
    const tip = document.getElementById('tooltip');
    function showTip(evt, d) {
      const teamPayroll = d.parent.value;
      tip.innerHTML =
        `<div class="tt-name">${d.data.name}</div>` +
        `<div class="tt-team">${d.parent.data.name}</div>` +
        `<div class="tt-salary">${fmtUSD(d.data.salary)}</div>` +
        `<div class="tt-share">${pct(d.data.salary / teamPayroll)} of team payroll` +
        ` · ${pct(d.data.salary / CAP)} of the cap</div>`;
      tip.hidden = false;
      const pad = 16;
      let x = evt.clientX + pad;
      let y = evt.clientY + pad;
      const r = tip.getBoundingClientRect();
      if (x + r.width > window.innerWidth - 8) x = evt.clientX - r.width - pad;
      if (y + r.height > window.innerHeight - 8) y = evt.clientY - r.height - pad;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
    }

    leaf
      .style('cursor', 'crosshair')
      .on('mouseenter mousemove', function (evt) {
        const d = d3.select(this).datum();
        showTip(evt, d);
        hi.style('display', null);
        hiBack.attr('x', d.x0).attr('y', d.y0).attr('width', d.x1 - d.x0).attr('height', d.y1 - d.y0);
        hiFront.attr('x', d.x0).attr('y', d.y0).attr('width', d.x1 - d.x0).attr('height', d.y1 - d.y0);
      })
      .on('mouseleave', function () {
        tip.hidden = true;
        hi.style('display', 'none');
      });
  </script>

  <style>
    .viz-head { max-width: 820px; margin-bottom: 22px; }
    .tag {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      background: var(--ink);
      color: var(--paper);
      padding: 2px 8px;
    }
    .viz-head h1 {
      font-size: clamp(28px, 5vw, 46px);
      letter-spacing: -0.03em;
      line-height: 1.03;
      margin: 12px 0 10px;
    }
    .lede { font-size: 17px; color: #333; margin: 0 0 18px; }
    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 28px;
      margin: 0;
      padding: 14px 0 0;
      border-top: 4px solid var(--ink);
    }
    .stats div { margin: 0; }
    .stats dt {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #666;
    }
    .stats dd { margin: 2px 0 0; font-size: 22px; font-weight: 800; letter-spacing: -0.01em; }

    .chart-figure { margin: 0; }
    #chart-container { border: 4px solid var(--ink); background: #161616; line-height: 0; }
    #chart { width: 100%; height: auto; display: block; }
    figcaption { font-size: 13px; color: #555; margin-top: 12px; max-width: 820px; line-height: 1.5; }

    .tooltip {
      position: fixed;
      z-index: 10;
      pointer-events: none;
      background: #161616;
      color: var(--paper);
      border: 2px solid var(--paper);
      padding: 8px 11px;
      max-width: 260px;
      box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.35);
    }
    .tooltip[hidden] { display: none; }
    .tt-name { font-weight: 800; font-size: 15px; letter-spacing: -0.01em; }
    .tt-team { font-size: 12px; opacity: 0.75; margin-top: 1px; }
    .tt-salary { font-size: 17px; font-weight: 800; color: var(--yellow); margin-top: 5px; }
    .tt-share { font-size: 11.5px; opacity: 0.8; margin-top: 3px; }
  </style>
</Base>
